{
  "name": "garca-branca-gestao",
  "version": "0.2.0",
  "description": "Plataforma de gestão rural com IA da Fazenda Garça Branca",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbopack": "next dev --turbopack",
