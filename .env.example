# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Também deve existir como secret no ambiente "production" do GitHub Actions
# para copiar os objetos privados do Storage e registrar o ensaio de restauração.

# Bootstrap do primeiro administrador (usado somente por create-admin.ts)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrador

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_TASK_REMINDER_TEMPLATE=
WHATSAPP_TASK_REMINDER_LANGUAGE=pt_BR
WHATSAPP_ALERT_REMINDER_TEMPLATE=
CRON_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Números autorizados em formato internacional, separados por vírgula
WHATSAPP_ALLOWED_PHONES=
# Remetente usado apenas pelo smoke; se vazio, usa o primeiro número autorizado
WHATSAPP_SMOKE_TEST_PHONE=

# Inteligência artificial
OPENAI_API_KEY=
AI_PROVIDER=openai
OPENAI_MODEL=gpt-5.6

# URL pública do ambiente, sem barra final
APP_BASE_URL=

# Fuso civil usado para datas operacionais da fazenda
APP_TIMEZONE=America/Porto_Velho
